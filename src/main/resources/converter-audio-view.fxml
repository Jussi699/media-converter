<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" prefWidth="630.0" spacing="10.0" style="-fx-background-color: #4b4b4b;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="converter.ConverterAudioViewController">


    <Label alignment="CENTER" prefWidth="260.0"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: RED"
           text="Audio Converter">
        <VBox.margin>
            <Insets top="10.0" bottom="10"/>
        </VBox.margin>
    </Label>

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="btnSelectAudioVideoFile" mnemonicParsing="false" onAction="#onSelectAudioVideoPressed" prefWidth="170.0" text="Select audio/video" />

        <Button fx:id="btnChoiceDirForSaveMP3" mnemonicParsing="false" onAction="#onSelectOutputDirectoryPressed" prefWidth="170.0" text="Directory for save" />
    </HBox>


    <HBox alignment="CENTER" spacing="20.0" translateY="2.5">
        <ToggleButton fx:id="btnToMP3" mnemonicParsing="false"
                      onAction="#onFormatMp3Pressed"
                      prefWidth="100.0"
                      text="to MP3"/>

        <ToggleButton fx:id="btnToAAC" mnemonicParsing="false"
                      onAction="#onFormatAACPressed"
                      prefWidth="100.0"
                      text="to AAC"/>

        <ToggleButton fx:id="btnToOggVorbis" mnemonicParsing="false"
                      onAction="#onFormatOggPressed"
                      prefWidth="100.0"
                      text="to OGG"/>

        <ToggleButton fx:id="btnToOPUS" mnemonicParsing="false"
                      onAction="#onFormatOpusPressed"
                      prefWidth="100.0"
                      text="to OPUS"/>
    </HBox>

    <HBox alignment="CENTER" spacing="15.0" translateY="5">
        <ToggleButton fx:id="btnToFLAC" mnemonicParsing="false"
                      onAction="#onFormatFlacPressed"
                      prefWidth="100.0"
                      text="to FLAC"/>

        <ToggleButton fx:id="btnToALAC" mnemonicParsing="false"
                      onAction="#onFormatAlacPressed"
                      prefWidth="100.0"
                      text="to ALAC"/>

        <ToggleButton fx:id="btnToWAV" mnemonicParsing="false"
                      onAction="#onFormatWAvPressed"
                      prefWidth="100.0"
                      text="to WAV"/>

        <ToggleButton fx:id="btnToAIFF" mnemonicParsing="false"
                      onAction="#onFormatAiffPressed"
                      prefWidth="100.0"
                      text="to AIFF"/>
    </HBox>

    <HBox alignment="CENTER" spacing="20.0" translateY="10.0">
        <ComboBox fx:id="comboBoxChoiceBitRate" onAction="#onChoiceBitRate" prefWidth="120.0" />

        <ComboBox fx:id="comboBoxChoiceChannels" onAction="#onChoiceChannels" prefWidth="120.0" />

        <ComboBox fx:id="comboBoxChoiceSamplingRate" onAction="#onChoiceSamplingRate" prefWidth="120.0" />
    </HBox>

    <StackPane>
        <VBox.margin>
            <Insets top="15.0" bottom="5"/>
        </VBox.margin>
        <HBox alignment="CENTER" spacing="10.0">
            <Button fx:id="btnSubmitConvert"
                    mnemonicParsing="false"
                    onAction="#onStartConversionPressed"
                    prefWidth="210.0" text="Convert and Download" />

            <Button mnemonicParsing="false"
                    onAction="#onCancelConversation"
                    prefWidth="210.0" text="Cancel Conversation" />
        </HBox>
    </StackPane>

    <VBox alignment="CENTER" spacing="10.0">
        <VBox.margin>
            <Insets top="25.0" bottom="5.0" />
        </VBox.margin>
        <ProgressBar fx:id="progressBarConvert"
                     prefWidth="200.0"
                     minHeight="15"
                     progress="0.0"/>

        <StackPane prefHeight="8.0">
            <Label fx:id="labelSuccessConvert"
                   alignment="CENTER"
                   prefWidth="400.0"
                   textFill="#32CD32"
                   text="Convert has been success!">
                <style>-fx-font-weight: bold;</style>
            </Label>
        </StackPane>
        <VBox.margin>
            <Insets bottom="0" />
        </VBox.margin>
    </VBox>


    <StackPane fx:id="dropZone" styleClass="drop-zone"
               onDragOver="#handleDragOver"
               onDragDropped="#handleDragDropped"
               minHeight="250.0"
               prefHeight="250.0"
               prefWidth="560.0"
               VBox.vgrow="ALWAYS"
               style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 10;">
        <VBox.margin>
            <Insets top="5.0" bottom="10.0" />
        </VBox.margin>
            <Label fx:id="textDragZone" text="Drag files here" textFill="WHITE" style="-fx-font-size: 18px;" />
    </StackPane>

    <VBox alignment="CENTER" spacing="10.0">
        <Button mnemonicParsing="false"
                onAction="#onResetPressed"
                prefWidth="220.0" text="Reset" />
    </VBox>

    <padding>
        <Insets bottom="16.0" left="16.0" right="16.0" />
    </padding>
</VBox>
