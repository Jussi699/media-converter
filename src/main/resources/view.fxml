<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.ComboBox?>

<AnchorPane fx:id="AnchorPane" prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="converter.Controller">

    <children>
        <Pane fx:id="mainPane" prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: #2b2b2b;">

            <children>
                <Pane prefHeight="600.0" prefWidth="300.0" style="-fx-background-color: #4b4b4b;">
                    <children>
                        <Label fx:id="LabelConvertPhoto"
                               alignment="CENTER"
                               layoutX="75.0"
                               layoutY="14.0"
                               prefWidth="150.0"
                               text="Convert Photo"
                               textFill="RED" />

                        <Button fx:id="btnSelectPhotoFile"
                                layoutX="104.0"
                                layoutY="81.0"
                                mnemonicParsing="false"
                                onMouseClicked="#ActionBtnSelectFile"
                                text="Select image" />

                        <Button fx:id="btnChoiceDirForSaveImage"
                                layoutX="75.0"
                                layoutY="136.0"
                                mnemonicParsing="false"
                                onMouseClicked="#btnChoiceDirForSaveImage"
                                prefHeight="25.0"
                                prefWidth="150.0"
                                text="Directory for save" />

                        <ToggleButton fx:id="btnToPNG"
                                      layoutX="40.0"
                                      layoutY="200.0"
                                      mnemonicParsing="false"
                                      onMouseClicked="#ActionBtnToPNG"
                                      prefHeight="25.0"
                                      prefWidth="67.0"
                                      text="to PNG" />

                        <ToggleButton fx:id="btnToJPEG"
                                      layoutX="116.0"
                                      layoutY="200.0"
                                      mnemonicParsing="false"
                                      onMouseClicked="#ActionBtnToJPEG"
                                      prefHeight="25.0"
                                      prefWidth="67.0"
                                      text="to JPEG" />
                        <ComboBox fx:id="ComboBoxIcoSize"
                                      layoutX="192.0"
                                      layoutY="200.0"
                                      onAction="#onChoiceIcoSize"
                                      prefHeight="25.0"
                                      prefWidth="70.0"
                                       />

                        <Button fx:id="btnSubmitConvert"
                                layoutX="75.0"
                                layoutY="270.0"
                                mnemonicParsing="false"
                                onMouseClicked="#SubmitConvertAndDownload"
                                prefHeight="25.0"
                                prefWidth="150.0"
                                text="Confirm convert" />

                        <Label fx:id="LabelSelectImageName"
                               alignment="BOTTOM_LEFT"
                               layoutX="10.0"
                               layoutY="570.0"
                               prefWidth="280.0"
                               prefHeight="20"
                               text="none"
                               textFill="RED"
                                />
                        <Label fx:id="LabelSuccessConvert"
                               alignment="CENTER"
                               layoutX="10.0"
                               layoutY="300.0"
                               prefWidth="280.0"
                               prefHeight="20"
                               textFill="#32CD32" />
                    </children>
                </Pane>
                <Pane layoutX="700.0" prefHeight="600.0" prefWidth="300.0" style="-fx-background-color: #4b4b4b;" />

            </children>
        </Pane>
    </children>
</AnchorPane>
