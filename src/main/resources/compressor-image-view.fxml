<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER"
      prefHeight="820.0"
      prefWidth="630.0"
      spacing="14.0"
      style="-fx-background-color: #4b4b4b;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="media_multitool.CompressorImageController">

    <Label alignment="CENTER"
           prefWidth="220.0"
           text="Compressor Image"
           textFill="RED"
           style="-fx-font-size: 22px; -fx-font-weight: bold;">
        <VBox.margin>
            <Insets top="8.0"/>
        </VBox.margin>
    </Label>

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="btnSelectPhotoFile"
                mnemonicParsing="false"
                onAction="#ActionBtnSelectFile"
                prefWidth="150.0"
                text="Select image"/>

        <Button fx:id="btnChoiceDirForSaveImage"
                mnemonicParsing="false"
                onAction="#btnChoiceDirForSaveImage"
                prefWidth="150.0"
                text="Directory for save"/>
    </HBox>

    <HBox alignment="CENTER" spacing="20.0">
        <ComboBox fx:id="comboBoxScaleImage"
                  onAction="#onChoiceScaleImage"
                  prefWidth="85.0"/>

        <ComboBox fx:id="comboBoxOutputQuality"
                  onAction="#onChoiceOutputQuality"
                  prefWidth="85.0"/>
    </HBox>

    <VBox alignment="CENTER" spacing="8.0">
        <Label fx:id="labelSuccessConvert"
               alignment="CENTER"
               prefWidth="560.0"
               minHeight="20.0"
               prefHeight="20.0"
               visible="false"
               managed="true"
               text="Compression status"
               textFill="#32CD32"
               wrapText="true"
               style="-fx-font-weight: bold; -fx-font-size: 14px;" />

        <Button mnemonicParsing="false"
                onAction="#submitCompressAndDownload"
                prefWidth="220.0"
                text="Convert and Download" />
    </VBox>

    <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
        <VBox alignment="CENTER" spacing="8.0">
            <Label text="Original" textFill="RED"/>
            <ScrollPane fx:id="scrollPanePhotoOriginal"
                        fitToHeight="true"
                        fitToWidth="true"
                        pannable="true"
                        prefWidth="270.0"
                        prefHeight="320.0"
                        VBox.vgrow="ALWAYS">
                <StackPane fx:id="imageContainerOriginal"
                           minHeight="345.0"
                           minWidth="250.0">
                    <Group>
                        <ImageView fx:id="imageViewPhotoOriginal"
                                   fitHeight="345.0"
                                   fitWidth="250.0"
                                   pickOnBounds="true"
                                   preserveRatio="true"/>
                    </Group>
                </StackPane>
            </ScrollPane>
        </VBox>

        <VBox alignment="CENTER" spacing="8.0" >
            <Label text="Compressed" textFill="RED"/>
            <ScrollPane fx:id="scrollPanePhotoCompressed"
                        fitToHeight="true"
                        fitToWidth="true"
                        pannable="true"
                        prefWidth="270.0"
                        prefHeight="320.0"
                        VBox.vgrow="ALWAYS">
                <StackPane fx:id="imageContainerCompressed"
                           minHeight="345.0"
                           minWidth="250.0">
                    <Group>
                        <ImageView fx:id="imageViewPhotoCompressed"
                                   fitHeight="345.0"
                                   fitWidth="250.0"
                                   pickOnBounds="true"
                                   preserveRatio="true"/>
                    </Group>
                </StackPane>
            </ScrollPane>
        </VBox>
    </HBox>

    <VBox alignment="CENTER" spacing="6.0">
        <Label fx:id="labelSelectImageName"
               alignment="CENTER"
               prefWidth="600.0"
               minHeight="18.0"
               text="none"
               textFill="RED"
               wrapText="true"/>

        <Button mnemonicParsing="false"
                onAction="#isPressedReset"
                prefWidth="220.0"
                text="Reset"/>
    </VBox>

    <padding>
        <Insets top="8.0" left="16.0" right="16.0" bottom="16.0"/>
    </padding>
</VBox>
